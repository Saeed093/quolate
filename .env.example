# Host port 5433 maps to the Postgres container (see docker-compose.yml)
DATABASE_URL=postgresql+psycopg://quolate:quolate@localhost:5433/quolate
# Separate database used by the pytest suite (created automatically if missing)
TEST_DATABASE_URL=postgresql+psycopg://quolate:quolate@localhost:5433/quolate_test
JWT_SECRET=change-me
# Admin console credentials (compliance view at /admin). CHANGE for production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1963
FILE_STORAGE_PATH=./data/files
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
# qwen3:8b on the 8GB machine, qwen3:4b on the 4GB machine
LLM_MODEL=qwen3:8b
LLM_NUM_CTX=8192
# Use Ollama's native /api/chat (honors num_ctx/keep_alive; the /v1 shim
# does not). Set false for hosted OpenAI-compatible APIs.
LLM_NATIVE_OLLAMA=true
# GPU-only chat: chat is refused unless the model is fully in GPU VRAM.
# Set false to allow CPU chat (not recommended).
LLM_REQUIRE_GPU_FOR_CHAT=true
# How long Ollama keeps the model warm after 'Start GPU' / each LLM call
LLM_KEEP_ALIVE=2h
# Timeout for POST /gpu/start to load the model onto the GPU
GPU_LOAD_TIMEOUT_SECONDS=300
EMBEDDING_MODEL=bge-m3
OCR_LANGS=en,ch
SCRAPE_CRON=0 7 * * *
ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
