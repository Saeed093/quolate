# Host port 5433 maps to the Postgres container (see docker-compose.yml)
DATABASE_URL=postgresql+psycopg://quolate:quolate@localhost:5433/quolate
# Separate database used by the pytest suite (created automatically if missing)
TEST_DATABASE_URL=postgresql+psycopg://quolate:quolate@localhost:5433/quolate_test
JWT_SECRET=change-me
FILE_STORAGE_PATH=./data/files
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
# qwen3:8b on the 8GB machine, qwen3:4b on the 4GB machine
LLM_MODEL=qwen3:8b
LLM_NUM_CTX=8192
EMBEDDING_MODEL=bge-m3
OCR_LANGS=en,ch
SCRAPE_CRON=0 7 * * *
ALLOW_ORIGINS=http://localhost:3000
